# Required
# DISCORD_TOKEN=your-bot-token-here

# LLM provider (pick one — or leave all blank to use local Ollama)
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# LLM_MODEL=                        # override default model for any provider

# Optional
# GITHUB_TOKEN=ghp_...              # enables /capture, /digest → GitHub PR
# GITHUB_REPO=JacobHind/detroitdotdev
# NOTIFICATION_CHANNEL_ID=123456789

# Auto-digest: bot watches channels and captures knowledge automatically
# WATCH_CHANNELS=123456789,987654321  # comma-separated channel IDs, or "all"
# DIGEST_QUIET_MINUTES=10             # minutes of quiet before evaluating
# DIGEST_MIN_MESSAGES=8               # minimum messages before evaluating
